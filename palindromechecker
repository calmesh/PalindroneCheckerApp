    // Usecase 1
    static void usecase1() {

        String input = "madam";
        boolean isPalindrome = true;

        for (int j = 0; j < input.length() / 2; j++) {
            if (input.charAt(j) != input.charAt(input.length() - 1 - j)) {
                isPalindrome = false;
                break;
            }
        }

        System.out.println("Input: " + input);
        System.out.println("Is Palindrome?: " + isPalindrome);
    }

